{
  "name": "dashboard-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3001",
    "test": "node --import tsx --test src/**/*.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "security:public-assets": "tsx scripts/assert-no-private-public-assets.ts",
    "ci:verify": "npm run security:public-assets && npm run lint && npm run typecheck && npm run build",
    "collect:yandex-webmaster": "bash scripts/collect-yandex-webmaster-canonical.sh --run-type cron",
    "db:migrate": "tsx src/db/run-migration.ts",
    "deploy": "bash scripts/deploy.sh",
    "deploy:rollback": "bash scripts/rollback-release.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/funnel": "^0.99.0",
    "@nivo/heatmap": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@nivo/scatterplot": "^0.99.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@visx/geo": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.19.1",
    "next": "16.1.6",
    "papaparse": "^5.5.3",
    "puppeteer": "^24.39.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "world-atlas": "^2.0.2",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
